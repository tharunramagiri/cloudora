# Cloudora - Environment Configuration

# Telegram Bot Tokens (one per line in tokens.txt, or comma-separated here)
BOT_TOKENS=

# Telegram Channel ID (must be a private channel with bots added as admins)
CHANNEL_ID=

# Admin API Key for accessing the dashboard and API
ADMIN_API_KEY=change-me-to-a-secure-key

# Server Configuration
HOST=0.0.0.0
PORT=8080
BASE_URL=https://cloud.ramagiritharun.in

# Database
DATABASE_PATH=data/cloudora.db

# Optional: Proxy for Telegram (if your server restricts Telegram)
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USER=
# PROXY_PASS=
